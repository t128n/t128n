{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"strictNullChecks": true,
		"allowJs": true,
		"types": ["@atcute/atproto", "@atcute/standard-site"],
		"paths": {
			"~/*": ["./src/*"],
			"public/*": ["./public/*"],
			"assets/*": ["./src/assets/*"],
			"~~/*": ["./*"]
		}
	}
}
