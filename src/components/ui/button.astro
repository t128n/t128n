---
import { mergeClasses } from '~/lib/styles';

interface Props {
  href?:          string;
  target?:        string;
  rel?:           string;
  icon?:          string;           // UnoCSS icon class, e.g. 'i-simple-icons:github'
  iconPosition?:  'left' | 'right';
  variant?:       'outline' | 'solid' | 'ghost';
  size?:          'sm' | 'md' | 'lg';
  class?:         string;
  [key: string]:  unknown;          // passthrough for aria-*, data-*, etc.
}

const {
  href,
  target,
  rel,
  icon,
  iconPosition = 'left',
  variant      = 'outline',
  size         = 'sm',
  class: className,
  ...rest
} = Astro.props;

const variantClasses = {
  outline: 'border border-primary/50 text-primary bg-transparent hover:bg-primary/10',
  solid:   'bg-primary text-primary-foreground hover:bg-primary/90',
  ghost:   'text-primary hover:bg-primary/10',
};

const sizeClasses = {
  sm: 'px-2 py-1 text-sm',
  md: 'px-3 py-1.5 text-sm',
  lg: 'px-4 py-2 text-base',
};

const classes = mergeClasses(
  'inline-flex items-center gap-1 font-medium transition-colors rounded-sm cursor-pointer',
  variantClasses[variant],
  sizeClasses[size],
  className,
);

const Tag = href ? 'a' : 'button';
---

<Tag
  class={classes}
  href={href}
  target={href ? target : undefined}
  rel={href && target === '_blank' ? (rel ?? 'noopener noreferrer') : rel}
  {...rest}
>
  {icon && iconPosition === 'left'  && <span class={`${icon} inline-flex shrink-0`} />}
  <slot />
  {icon && iconPosition === 'right' && <span class={`${icon} inline-flex shrink-0`} />}
</Tag>
