---
import { mergeClasses } from '~/lib/styles';

interface Props {
  href?:          string;
  target?:        string;
  rel?:           string;
  icon?:          string;           // UnoCSS icon class, e.g. 'i-simple-icons:github'
  iconSize?:      'sm' | 'md' | 'lg' | 'xl'; // Optional size for the icon, defaults to the button size
  iconPosition?:  'left' | 'right';
  size?:          'sm' | 'md' | 'lg' | 'xl';
  class?:         string;
  [key: string]:  unknown;          // passthrough for aria-*, data-*, etc.
}

const {
  href,
  target,
  rel,
  icon,
  iconPosition = 'left',
  size         = 'sm',
  iconSize = size,
  class: className,
  ...rest
} = Astro.props;

const sizeClasses = {
  sm: 'text-sm',
  md: 'text-sm',
  lg: 'text-base',
  xl: 'text-lg',
};

const iconSizeClasses = {
  sm: 'text-sm',
  md: 'text-sm',
  lg: 'text-base',
  xl: 'text-lg',
};

const classes = mergeClasses(
  'inline-flex items-center gap-1 underline-offset-3 underline hover:no-underline hover:bg-foreground hover:text-background transition-colors cursor-pointer',
  sizeClasses[size],
  className,
);

const Tag = href ? 'a' : 'button';
---

<Tag
  class={classes}
  href={href}
  target={href ? target : undefined}
  rel={href && target === '_blank' ? (rel ?? 'noopener noreferrer') : rel}
  {...rest}
>
  {icon && iconPosition === 'left'  && <span class={`${icon} inline-flex shrink-0 ${iconSizeClasses[iconSize]}`} />}
  <slot />
  {icon && iconPosition === 'right' && <span class={`${icon} inline-flex shrink-0 ${iconSizeClasses[iconSize]}`} />}
</Tag>
