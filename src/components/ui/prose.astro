---
import { mergeClasses } from '~/lib/styles';

interface Props {
	as?: 'article' | 'div';
	class?: string;
	[key: string]: unknown;
}

const { as = 'div', class: className, ...rest } = Astro.props as Props;

const classes = mergeClasses(
	'prose w-full max-w-none pb-6 dark:prose-invert prose-headings:font-normal prose-h2:text-xl prose-h3:text-lg prose-h4:text-base prose-h5:text-sm prose-h6:text-xs prose-a:underline-offset-3 hover:prose-a:bg-foreground hover:prose-a:text-background hover:prose-a:no-underline',
	className,
);
---

{as === 'article' ? (
	<article class={classes} {...rest}>
		<slot />
	</article>
) : (
	<div class={classes} {...rest}>
		<slot />
	</div>
)}
