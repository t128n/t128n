---
import { createHead, renderSSRHead } from 'unhead/server';
import { Font } from 'astro:assets';
import { useVerify } from '~/composables/use-verify';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  atUri?: string;
}

const {
  title = 't128n.dev',
  description = '',
  lang = 'en',
  canonical = new URL(Astro.url.pathname.replace(/\/index\.html$/, '/').replace(/\.html$/, ''), Astro.url.origin).href,
  ogImage,
  ogType = 'website',
  atUri,
} = Astro.props as Props;

const pathname = Astro.url.pathname;
const slug = pathname.replace(/^\/+|\/+$/g, '').replace(/\.html$/, '');
const defaultOgImage = new URL(
  slug === ''
    ? '/og/index.png'
    : `/og/${slug}.png`,
  Astro.url.origin,
).href;
const resolvedOgImage = ogImage ?? defaultOgImage;

const head = createHead({
  init: [{ htmlAttrs: { lang } }],
});

head.push({
  title,
  titleTemplate: '%s @ t128n.dev',
  meta: [
    { charset: 'utf-8' },
    { name: 'viewport', content: 'width=device-width, initial-scale=1' },
    { name: 'generator', content: Astro.generator },
    ...(description ? [{ name: 'description', content: description }] : []),
    { property: 'og:title', content: title },
    { property: 'og:type', content: ogType },
    { property: 'og:url', content: canonical },
    ...(description
      ? [{ property: 'og:description', content: description }]
      : []),
    { property: 'og:image', content: resolvedOgImage },
  ],
  link: [
    { rel: 'icon', href: '/favicon.ico' },
    { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
    { rel: 'apple-touch-icon', href: '/apple-touch-icon.png' },
    { rel: 'canonical', href: canonical },
    { rel: 'sitemap', type: 'application/xml', href: '/sitemap.xml' },
    { rel: 'alternate', type: 'application/rss+xml', title: `${title} @ t128n.dev`, href: '/feed.xml' },
    {
      rel: 'stylesheet',
      href: 'https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css',
      integrity: 'sha384-zh0CIslj+VczCZtlzBcjt5ppRcsAmDnRem7ESsYwWwg3m/OaJ2l4x7YBZl9Kxxib',
      crossorigin: 'anonymous',
    },
    ...useVerify(),
    ...(atUri ? [{ rel: 'site.standard.document', href: atUri }] : []),
  ],
});

const { headTags, bodyAttrs, bodyTagsOpen  } = await renderSSRHead(head);
---

<!doctype html>
<html lang={lang}>
  <head>
    <Fragment set:html={headTags} />
    <Font cssVariable="--font-ia-writer-duo" preload={[{ weight: 400, style: 'normal' }, { weight: 700, style: 'normal' }]} />
    <Font cssVariable="--font-ia-writer-mono" preload={[{ weight: 400, style: 'normal' }, { weight: 700, style: 'normal' }]} />
  </head>
  <body set:html={bodyAttrs} class='min-h-dvh flex flex-col bg-background text-foreground font-sans'>
    <slot />
    <Fragment set:html={bodyTagsOpen ?? ''} />
  </body>
</html>
