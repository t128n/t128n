---
import Root from './root.astro';
import type { Props as RootProps } from './root.astro';

interface Props extends RootProps {}
---

<Root {...Astro.props}>
  <div class="flex flex-col grow">
    <div class="flex flex-1 border-b border-default">
      <div class="flex-1 border-r border-default" />
      <div class="w-full sm:max-w-[40rem]" />
      <div class="flex-1 border-l border-default" />
    </div>
    <div class="flex">
      <div class="flex-1 border-r border-default" />
      <div class="w-full sm:max-w-[40rem] px-8 py-8 flex flex-col gap-4">
        <slot />
      </div>
      <div class="flex-1 border-l border-default" />
    </div>
    <div class="flex flex-1 border-t border-default">
      <div class="flex-1 border-r border-default" />
      <div class="w-full sm:max-w-[40rem]" />
      <div class="flex-1 border-l border-default" />
    </div>
  </div>
</Root>
