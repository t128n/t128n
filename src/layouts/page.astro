---
import Root from './root.astro';
import type { Props as RootProps } from './root.astro';

import AppHeader from '~/components/app-header.astro';
import AppFooter from '~/components/app-footer.astro';
import Prose from '~/components/ui/prose.astro';

interface Props extends RootProps {
    showHeading?: boolean;
    prose?: boolean;
}

type Frontmatter = {
	title?: string;
	description?: string;
	prose?: boolean;
};

const {
	showHeading: _showHeading = true,
	prose: _prose = false,
	frontmatter,
	title,
	description,
	...rootProps
} = Astro.props as Props & { frontmatter?: Frontmatter };

const prose = _prose || frontmatter?.prose;
const resolvedTitle = title ?? frontmatter?.title;
const resolvedDescription = description ?? frontmatter?.description;
const showHeading = _showHeading && (resolvedTitle || resolvedDescription);
---

<Root {...rootProps} title={resolvedTitle} description={resolvedDescription}>
	<AppHeader>
		<slot name="header" />
	</AppHeader>
	<main class="grow flex flex-col px-8 py-8 gap-8 max-w-[50rem]">
		<slot name="bleed" />
		{showHeading && (
			<div class="flex flex-col gap-3">
				{resolvedTitle && <h2 class="text-3xl">{resolvedTitle}</h2>}
				{resolvedDescription && <p>{resolvedDescription}</p>}
			</div>
		)}
		{prose ? (
			<Prose>
				<slot />
			</Prose>
		) : (
			<slot />
		)}
	</main>
    <AppFooter>
        <slot name="header" />
    </AppFooter>
</Root>
