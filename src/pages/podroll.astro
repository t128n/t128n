---
import Page from '~/layouts/page.astro';
import LinkList from '~/components/link-list.astro';
import { getPodrollEntries } from '~/lib/rolls';

const podcastsWithMeta = await getPodrollEntries();

export const meta = {
    title: 'Podroll',
    description: 'Collection of podcasts I listen to regularly.',
    icon: 'i-gg:media-podcast'
};
---

<Page title={meta.title} description={meta.description}>
    <LinkList
        items={podcastsWithMeta.map((podcast) => ({
            href: podcast.url,
            title: podcast.title,
            description: podcast.description,
            image: podcast.image,
        }))}
        icon="i-gg:media-podcast"
    />
</Page>
