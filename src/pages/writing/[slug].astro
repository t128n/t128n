---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Page from '~/layouts/page.astro';
import Breadcrumb from '~/components/breadcrumb.astro';
import BlueskyIntegration from '~/components/bluesky-integration.svelte';
import Prose from '~/components/ui/prose.astro';

const coverImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/images/*.{jpg,jpeg,png,webp}',
);

export async function getStaticPaths() {
	const entries = await getCollection('writings', ({ data, id }) => data.draft !== true && id !== 'index');
	return entries
		.map((entry) => ({
			params: { slug: entry.id },
			props: { entry },
		}));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);

const updatedAt = entry.data.updatedAt ?? (remarkPluginFrontmatter.updatedAt ? new Date(remarkPluginFrontmatter.updatedAt) : undefined);

const cover = entry.data.cover;
const blueskyUrl = entry.data.blueskyUrl;
let coverSrc: ImageMetadata | null = null;

if (cover && typeof cover === 'object') {
	const href = cover.href.startsWith('/') ? cover.href : `/${cover.href}`;
	const loadCover = coverImages[href];
	if (loadCover) {
		coverSrc = (await loadCover()).default;
	}
}
---

<Page title={entry.data.title} description={entry.data.description}>
	<Fragment slot="bleed">
		<Breadcrumb
			items={[
				{ href: '/', label: 't128n.dev' },
				{ href: '/writing/', label: 'writings' },
				{ label: entry.data.title },
			]}
		/>
	</Fragment>
	{coverSrc && (
		<div slot="bleed" class="aspect-[21/9] w-full overflow-hidden border-b border-default">
			<Image src={coverSrc} alt={typeof cover === 'object' ? cover.caption : ''} class="block h-full w-full object-cover object-center" />
		</div>
	)}
	<Prose as="article">
		<Content />
	</Prose>
	{updatedAt && (
		<footer class="flex justify-end gap-1 text-sm text-muted italic">
			Last updated on <time datetime={updatedAt.toISOString()}>{updatedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
		</footer>
	)}
	{blueskyUrl && <BlueskyIntegration blueskyUrl={blueskyUrl} client:load />}
</Page>
