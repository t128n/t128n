---
import { getCollection, render } from "astro:content";
import Page from "~/layouts/page.astro";
import LinkList from "~/components/link-list.astro";

export const meta = {
	title: "Writings",
	description: "On occasion, I write about stuff.",
};

type WritingListEntry = {
	data: {
		pubDate?: Date;
		createdAt?: Date;
	};
};

function getWritingDate(entry: WritingListEntry) {
	return entry.data.pubDate ?? entry.data.createdAt ?? null;
}

function formatWritingDate(entry: WritingListEntry) {
	const date = getWritingDate(entry);
	return date ? date.toISOString().split("T")[0] : null;
}

const entries = await getCollection("writings", ({ data, id }) => data.draft !== true && id !== "index");
const writings = await Promise.all(
	entries.map(async (entry) => {
		const { remarkPluginFrontmatter } = await render(entry);
		return {
			...entry,
			data: {
				...entry.data,
				pubDate:
					entry.data.pubDate ??
					(remarkPluginFrontmatter.createdAt ? new Date(remarkPluginFrontmatter.createdAt) : undefined),
				createdAt: entry.data.createdAt ?? (remarkPluginFrontmatter.createdAt ? new Date(remarkPluginFrontmatter.createdAt) : undefined),
				updatedAt: entry.data.updatedAt ?? (remarkPluginFrontmatter.updatedAt ? new Date(remarkPluginFrontmatter.updatedAt) : undefined),
			},
		};
	}),
);

writings.sort((a, b) => {
	const aDate = new Date(a.data.pubDate ?? a.data.createdAt ?? 0).getTime();
	const bDate = new Date(b.data.pubDate ?? b.data.createdAt ?? 0).getTime();
	return bDate - aDate;
});

---

<Page
	title={meta.title}
	description={meta.description}
>
	<LinkList
		items={writings.map((writing) => ({
			href: `/writing/${writing.id}`,
			title: writing.data.title,
			description: writing.data.description,
			meta: formatWritingDate(writing),
		}))}
		icon="i-gg:file-document"
		listClass="space-y-4"
		itemClass="block"
		iconWrapClass="hidden"
		titleClass="text-lg font-medium text-primary"
		metaClass="text-sm text-muted"
	/>
	<p class="mt-6 text-sm text-muted">Subscribe via <a href="/feed.xml" class="text-primary font-medium">RSS</a>.</p>
</Page>
