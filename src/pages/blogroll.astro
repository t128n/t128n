---
import Page from '~/layouts/page.astro';
import LinkList from '~/components/link-list.astro';
import { getBlogrollEntries } from '~/lib/rolls';

const blogsWithMeta = await getBlogrollEntries();

export const meta = {
    title: 'Blogroll',
    description: 'Collection of blogs that I read regularly.',
    icon: 'i-gg:readme'
};
---
<Page title={meta.title} description={meta.description}>
    <LinkList
        items={blogsWithMeta.map((blog) => ({
            href: blog.htmlUrl,
            title: blog.title,
            description: blog.description,
            image: blog.image,
        }))}
        icon="i-gg:link"
    />
</Page>
