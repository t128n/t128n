---
import Page from '~/layouts/page.astro';
import Profile from '~/components/profile.astro';
import Button from '~/components/ui/button.astro';
import { meta } from '~/config';
---

<Page title={meta.title} description={meta.description} showHeading={false}>
    <Profile
      name="Torben Haack"
      handle="t128n"
      avatar="/t128n.png"
      class="mb-2"
    />
    <p>
        <abbr class='cursor-help' title="Technical Product Owner">TPO</abbr> and <abbr class='cursor-help' title="Software Engineer">SE</abbr> in the automotive industry by day, FOSS & tech enthusiast by night.
        Developing and managing data and software systems. Part-time studying Business Informatics at <a class='underline-offset-3 hover:no-underline underline hover:bg-foreground hover:text-background' href="https://www.bht-berlin.de/en/" target="_blank">BHT Berlin</a>.
    </p>
    <p>
        Sometimes I also <a href="/writing" class='font-medium underline-offset-3 underline hover:no-underline hover:bg-foreground hover:text-background'>write about stuff</a>.
    </p>
    <p>
        Connect with me on...
        <ul class="flex flex-col items-start gap-1">
            <li>
                <Button href="/go/bsky" target="_blank" icon="i-simple-icons:bluesky" class="w-48" size="lg">Bluesky</Button>
            </li>
            <li>
                <Button href="/go/gh" target="_blank" icon="i-simple-icons:github" class="w-48" size="lg">GitHub</Button>
            </li>
            <li>
                <Button href="/go/linkedin" target="_blank" icon="i-simple-icons:linkedin" class="w-48" size="lg">LinkedIn</Button>
            </li>
            <li>
                <Button href="/verify" icon="i-gg:globe-alt" class="w-48" size="lg" iconSize='xl'>and elsewhere.</Button>
            </li>
        </ul>
    </p>
    <p>Or check out some things I built...</p>
    <ul class="flex flex-col items-start gap-1">
        <li>
          <Button href="https://github.com/t128n/packy" target="_blank" class="w-96" icon="i-gg:box" size="lg">packy.js.org</Button>
        </li>
        <li>
          <Button href="https://npmx.dev/package/vue-node-red-flow-viewer" icon="i-simple-icons:npm" target="_blank" class="w-96" size="lg">vue-node-red-flow-viewer</Button>
        </li>
        <li>
          <Button href="/tools" icon="i-gg:toolbox" target="_blank" class="w-96" size="lg">t128n.dev/tools</Button>
        </li>
    </ul>
</Page>
